<% /* Determine theme based on context */ let logoTheme='light' ; if (typeof theme !=='undefined' ) { logoTheme=theme; }
    else if (is_home()) { logoTheme='dark' ; } /* Define color classes based on theme - MONOCHROME ONLY */ let
    iconColorClass, textColorClass, gradientClass; if (logoTheme==='dark' ) { /* For dark backgrounds (home page) */
    iconColorClass='text-white' ; textColorClass='text-zinc-100' ;
    gradientClass='bg-gradient-to-r from-white via-zinc-200 to-zinc-400 bg-clip-text text-transparent' ; } else { /* For
    light backgrounds (detail pages, footer) */ iconColorClass='text-zinc-800 dark:text-zinc-200' ;
    textColorClass='text-zinc-800 dark:text-zinc-200' ;
    gradientClass='bg-gradient-to-r from-zinc-900 via-zinc-700 to-zinc-500 bg-clip-text text-transparent dark:from-white dark:via-zinc-300 dark:to-zinc-500'
    ; } %>
    <a href="/" title="Cheatly - Quick Reference and Cheat Sheets for Developers"
        class="flex font-medium items-center justify-center md:justify-start text-zinc-800 dark:text-zinc-300">
        <% if (icon) { %>
            <div class="justify-center <%= iconColorClass %> mr-3 text-4xl">
                <div class="self-center">
                    <%- icon("logo") %>
                </div>
            </div>
            <% } %>
                <span
                    class="hidden md:flex domain text-xl md:text-2xl lg:text-3xl font-bold tracking-tight font-['Space_Grotesk']">
                    <span class="<%= gradientClass %>">Cheatly</span>
                </span>
    </a>
    <% if (page.layout=="note" || page._isNotePagination){ %>
        <a class="hidden md:block" href="/notes/" title="Notes - Browse our developer notes and tutorials">
            <span
                class="flex items-center pl-2 ml-2 text-lg text-zinc-300 md:border-l border-zinc-400 dark:border-zinc-700 hover:text-white transition-colors">Notes</span>
        </a>
        <% } %>